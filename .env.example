# ================================================================
# SmartPeak — Variables para docker-compose (PRODUCCIÓN)
# ================================================================
# Copia este archivo a `.env` EN EL SERVIDOR y rellena los valores.
# El `.env` real NUNCA se commitea (está en .gitignore).
#
# Genera secretos seguros con:
#   openssl rand -base64 32

# ----- MongoDB (credenciales del contenedor mongo:7) -----
MONGO_USER=smartpeak
MONGO_PASSWORD=cambia-esta-contraseña-larga-y-aleatoria

# ----- JWT (OBLIGATORIOS, mínimo 16 caracteres) -----
# El backend hace process.exit(1) al arrancar si faltan.
JWT_ACCESS_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-largo-y-aleatorio

# ----- Origen del cliente (para CORS) -----
# Dominio público servido por Nginx Proxy Manager.
CLIENT_ORIGIN=https://smartpeak.joan-coll.com

# ----- URL de la API (build-arg del frontend) -----
# Relativa: mismo origen. El nginx del frontend proxya /api al backend.
# Normalmente NO hace falta cambiarla.
VITE_API_URL=/api

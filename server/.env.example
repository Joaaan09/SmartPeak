# Entorno de ejecución: development | production | test
NODE_ENV=development

# Puerto del servidor HTTP
PORT=4000

# Cadena de conexión a MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/smartpeak

# Secretos JWT (usa valores largos y aleatorios en producción)
JWT_ACCESS_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-largo-y-aleatorio

# Origen del cliente permitido por CORS
CLIENT_ORIGIN=http://localhost:5173
